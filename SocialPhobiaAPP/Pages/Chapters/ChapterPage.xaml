<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SocialPhobiaAPP.Pages.Chapters.ChapterPage"
             >
    <ScrollView>
        <Grid Margin="10,10,10,10">

            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="25"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="25"/>
            </Grid.ColumnDefinitions>


        
            <ImageButton Source="left_arrow.png" BorderColor="Blue" HeightRequest="15" HorizontalOptions="Start" Clicked="Back_Clicked" Grid.Column="0" Grid.Row="0"/>
            <ImageButton Source="close.png" BorderColor="Blue" HeightRequest="15" HorizontalOptions="End" Clicked="Close_Clicked"       Grid.Column="2" Grid.Row="0"/>

            <ProgressBar x:Name="ChapterProgressBar" ProgressColor="Green" Progress="{Binding Progress}" HeightRequest="30" Grid.Column="1" Grid.Row="1"/>

            <VerticalStackLayout Spacing="5" Grid.Row="2" Grid.Column="1">
                <Image Source="{Binding Image }" WidthRequest="200" HorizontalOptions="Center"/>
                <Label x:Name="Title" Text="{Binding Title }" FontAttributes="Bold" TextColor="#E9967A" FontSize="24" HorizontalOptions="Center"/>
                <Label x:Name="ChapterText" Text="{Binding  ChapterText}" FontSize="15" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <ImageButton Source="continue_arrow.png" BorderColor="Blue" HeightRequest="15" HorizontalOptions="End" Clicked="Next_Clicked" Grid.Column="2" Grid.Row="3"/>

        </Grid>
    </ScrollView>
</ContentPage>