<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SocialPhobiaAPP.Pages.Chapters.FinalChapterPage"
             >
    <VerticalStackLayout Spacing="10">
        <Image Source="check.png" HorizontalOptions="Center" HeightRequest="200" />
        <Label Text="Congratulations! You have completed the final chapter." HorizontalOptions="Center" FontAttributes="Bold" Margin="0,20,0,0"/>
        <Button Text="Finish chapter" Clicked="FinishButton_Clicked" HorizontalOptions="Center"/>
    </VerticalStackLayout>
</ContentPage>