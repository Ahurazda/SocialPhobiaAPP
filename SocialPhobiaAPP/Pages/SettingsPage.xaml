<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SocialPhobiaAPP.Pages.SettingsPage"
             >

    <VerticalStackLayout Padding="20">
        
        
        <ImageButton Source="left_arrow.png" Clicked="BackButton_Clicked" HorizontalOptions="Start" HeightRequest="50" WidthRequest="50"/>
        <Label Text="Settings" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,20"/>
        <HorizontalStackLayout Spacing="10" BackgroundColor="WhiteSmoke" VerticalOptions="Center">
            <Label Text="Dark theme:"  />
            <Switch x:Name="themeSwitch" Toggled="DarkThemeToggled" IsToggled="False"  HorizontalOptions="End"/>
        </HorizontalStackLayout>

        <BoxView HeightRequest="1" 
         BackgroundColor="Gray" 
         HorizontalOptions="Fill" 
         Margin="0,10" />
        

    </VerticalStackLayout>

</ContentPage>