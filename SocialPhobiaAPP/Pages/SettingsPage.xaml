<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SocialPhobiaAPP.Pages.SettingsPage"
             >

    <Grid Padding="20"  RowSpacing="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        
        <ImageButton Source="left_arrow.png" Clicked="BackButton_Clicked" HorizontalOptions="Start" HeightRequest="25" WidthRequest="25" Grid.Row="0"/>
        <Label Text="Settings" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" Grid.Row="0"/>
        <Border StrokeShape="RoundRectangle 20" Margin="0,25,0,0" Grid.Row="1">
        <Grid ColumnDefinitions="*, Auto"   Padding="5" >
            <Label Text="Switch theme:" VerticalOptions="Center" FontAttributes="Bold" Grid.Column="0"/>
            <Switch x:Name="themeSwitch" Toggled="DarkThemeToggled" OnColor="Green"  OffColor="LightGray" Grid.Column="1"/>
        </Grid>
        </Border>
        
        

    </Grid>

</ContentPage>